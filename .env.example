# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# --- Oura (official API v2) ---
# Create a Personal Access Token at https://cloud.ouraring.com/personal-access-tokens
OURA_TOKEN=

# --- Eight Sleep (unofficial) ---
# Your Eight Sleep account login. Used by the unofficial client.
EIGHTSLEEP_EMAIL=
EIGHTSLEEP_PASSWORD=

# --- Apple Health (via Health Auto Export app) ---
# Folder the Health Auto Export app writes JSON into (iCloud Drive recommended).
# Default points at an iCloud Drive subfolder; create it in the app's export settings.
APPLE_HEALTH_DIR=~/Library/Mobile Documents/com~apple~CloudDocs/HealthAutoExport
